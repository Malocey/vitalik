# Ein einzelner LM-Link-Gateway-Endpoint oder mehrere direkt erreichbare LM-Studio-PCs.
LOCAL_LLM_PROVIDER=lm_studio
LM_STUDIO_ENDPOINTS=http://192.168.1.101:1234/v1,http://192.168.1.102:1234/v1
LM_STUDIO_MODELS=google/gemma-4-12b-qat,supergemma-4-12b-abliterated

# Kommagetrennt und in derselben Reihenfolge wie LM_STUDIO_ENDPOINTS.
LM_STUDIO_API_TOKENS=token-pc-1,token-pc-2

# Gleichzeitige Pipeline-Aufgaben pro Rechner.
LLM_MAX_IN_FLIGHT_PER_ENDPOINT=1
LLM_REQUEST_TIMEOUT=120
LLM_FAILURE_COOLDOWN=30

DEFAULT_LLM_MODEL=google/gemma-3-12b
DEFAULT_EMBEDDING_MODEL=nomic-embed-text
